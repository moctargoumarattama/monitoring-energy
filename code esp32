// ============================================================
// CALIBRATION PIR
// ============================================================
void calibratePir() {
  logInfo("PIR", "Calibration en cours (20s)...");
  
  unsigned long startMs = millis();
  unsigned long lastUpdateMs = 0;
  
  while (millis() - startMs < PIR_CALIBRATION_MS) {
    unsigned long now = millis();
    if (now - lastUpdateMs >= 1000) {
      lastUpdateMs = now;
      int secondsLeft = (PIR_CALIBRATION_MS - (now - startMs)) / 1000 + 1;
      lcdShowCalibration(secondsLeft);
      digitalWrite(LED_ALERT_PIN, (secondsLeft % 2 == 0) ? HIGH : LOW);
    }
    delay(50);
  }
  
  digitalWrite(LED_ALERT_PIN, LOW);
  logInfo("PIR", "Calibration PIR terminee.");
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("PIR PRET !");
  lcd.setCursor(0, 1);
  lcd.print("Demarrage...");
  delay(1500);
}

