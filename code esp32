void lcdPadAndPrint(const String& text) {
  String t = text;
  while (t.length() < LCD_COLS) t += ' ';
  if (t.length() > LCD_COLS) t = t.substring(0, LCD_COLS);
  lcd.print(t);
}

void lcdScreenEnvironment(const TelemetrySnapshot& s) {
  lcd.setCursor(0, 0);
  String line1 = "T:";
  if (s.tempOk) {
    line1 += String(s.tempC, 1);
    line1 += "C ";
  } else {
    line1 += "ERR  ";
  }
  line1 += "H:";
  line1 += String((int)s.humidity);
  line1 += "%";
  lcdPadAndPrint(line1);
  
  lcd.setCursor(0, 1);
  String line2 = "Presence:";
  line2 += s.presence ? "OUI" : "NON";
  lcdPadAndPrint(line2);
}

