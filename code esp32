void connectWiFiBlocking() {
  WiFi.mode(WIFI_STA);
  WiFi.persistent(false);
  WiFi.setAutoReconnect(true);

  logInfo("WIFI", "Connexion: " + String(WIFI_SSID));
  lcdShowBoot("Connexion WiFi");
  
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 40) {
    delay(500);
    Serial.print(".");
    attempts++;
    
    if (attempts % 4 == 0) {
      lcd.setCursor(0, 1);
      String dots = "Tentative ";
      dots += String(attempts / 2);
      while (dots.length() < LCD_COLS) dots += ' ';
      lcd.print(dots);
    }
  }
  Serial.println();

  lcd.clear();
  lcd.setCursor(0, 0);
  if (WiFi.status() == WL_CONNECTED) {
    logInfo("WIFI", "Connecte. IP: " + WiFi.localIP().toString());
    lcd.print("WiFi OK");
    lcd.setCursor(0, 1);
    lcd.print(WiFi.localIP().toString());
  } else {
    logInfo("WIFI", "ECHEC connexion.");
    lcd.print("WiFi ERREUR");
    lcd.setCursor(0, 1);
    lcd.print("Mode hors-ligne");
  }
  delay(2000);
}

void ensureWiFiConnection() {
  if (WiFi.status() == WL_CONNECTED) return;
  
  const unsigned long now = millis();
  if (now - lastWiFiReconnectAttemptMs < WIFI_RECONNECT_INTERVAL_MS) return;
  
  lastWiFiReconnectAttemptMs = now;
  logInfo("WIFI", "Tentative reconnexion...");
  WiFi.disconnect();
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
}

// ============================================================
// LECTURE CAPTEURS
// ============================================================
void sampleDhtSensors(unsigned long nowMs, bool force = false) {
  if (!force && lastDhtSampleMs != 0 && (nowMs - lastDhtSampleMs) < DHT_SAMPLE_INTERVAL_MS) {
    return;
  }

  float h = dht.readHumidity();
  float t = dht.readTemperature();
  cachedTempOk = !isnan(t) && !isnan(h);
  cachedTempC = cachedTempOk ? t : 0.0f;
  cachedHumidity = cachedTempOk ? h : 0.0f;
  lastDhtSampleMs = nowMs;
}

bool readWindowOpen(unsigned long nowMs) {
  if (windowManualOverride) {
    return windowManualOpenState;
  }

  const bool rawWindowOpen = digitalRead(WINDOW_SENSOR_PIN) == WINDOW_SENSOR_OPEN_LEVEL;

  if (!windowSensorInitialized) {
    windowSensorInitialized = true;
    lastWindowSensorState = rawWindowOpen;
    lastWindowSensorChangeMs = nowMs;
    return rawWindowOpen;
  }

  if (rawWindowOpen == lastWindowSensorState) {
    return rawWindowOpen;
  }

  if ((nowMs - lastWindowSensorChangeMs) < 120UL) {
    return lastWindowSensorState;
  }

  lastWindowSensorState = rawWindowOpen;
  lastWindowSensorChangeMs = nowMs;
  return rawWindowOpen;
}

void initializePirTracking() {
  lastPirState = digitalRead(PIR_PIN) == HIGH;
  pirStateInitialized = true;
  lastPirEdgeMs = 0;
}

void processPirStateChange(unsigned long nowMs) {
  const bool currentPirState = digitalRead(PIR_PIN) == HIGH;

  if (!pirStateInitialized) {
    lastPirState = currentPirState;
    pirStateInitialized = true;
    lastPirEdgeMs = nowMs;
    return;
  }

  if (currentPirState == lastPirState) {
    return;
  }

  if (lastPirEdgeMs != 0 && (nowMs - lastPirEdgeMs) < PIR_EDGE_DEBOUNCE_MS) {
    return;
  }

  lastPirState = currentPirState;
  lastPirEdgeMs = nowMs;
  logInfo("PIR", currentPirState ? "Mouvement detecte - envoi immediat" : "Mouvement termine - envoi immediat");
  sendTelemetry();
  lastCycleMs = nowMs;
}

TelemetrySnapshot readTelemetry() {
  TelemetrySnapshot snapshot{};
  const unsigned long nowMs = millis();
  sampleDhtSensors(nowMs);
  snapshot.tempOk = cachedTempOk;
  snapshot.tempC = snapshot.tempOk ? cachedTempC : 0.0f;
  snapshot.humidity = snapshot.tempOk ? cachedHumidity : 0.0f;

  snapshot.presence = digitalRead(PIR_PIN) == HIGH;
  snapshot.windowOpen = readWindowOpen(nowMs);

  const int rawPot = analogRead(POT_PIN);
  const float ratio = rawPot / 4095.0f;
  snapshot.powerW = ratio * MAX_SIMULATED_POWER_W;
  snapshot.currentA = snapshot.powerW / VOLTAGE_REFERENCE_V;

  if (lastEnergyUpdateMs > 0) {
    const float deltaHours = (nowMs - lastEnergyUpdateMs) / 3600000.0f;
    energyAccumulatorKwh += (snapshot.powerW / 1000.0f) * deltaHours;
  }
  lastEnergyUpdateMs = nowMs;
  snapshot.energyTotalKwh = energyAccumulatorKwh;
  snapshot.costMad = energyAccumulatorKwh * PRICE_PER_KWH_MAD;

  snapshot.lampOn = lampState;
  snapshot.fanOn = fanState;
  snapshot.anomalyDhtFail = !snapshot.tempOk;
  snapshot.remoteEnabled = remoteEnabled;

  snapshot.criticalAlert = (snapshot.powerW > CRITICAL_POWER_W) ||
                            (snapshot.tempC > CRITICAL_TEMP_C);
  snapshot.generalAlert = snapshot.anomalyDhtFail || snapshot.criticalAlert;

  snapshot.alerts = 0;
  if (snapshot.anomalyDhtFail) snapshot.alerts++;
  if (snapshot.criticalAlert) snapshot.alerts++;

  setAlertLed(snapshot.generalAlert);
  setCriticalLed(snapshot.criticalAlert);
  setBuzzerActive(snapshot.generalAlert);

  if (snapshot.tempOk) {
    logInfo("DATA", "T=" + String(snapshot.tempC, 1) + "C H=" + 
                    String(snapshot.humidity, 0) + "% P=" +
                    String(snapshot.powerW, 0) + "W Pres=" +
                    String(snapshot.presence ? "OUI" : "NON"));
  } else {
    logInfo("DHT", "Lecture invalide.");
  }

  lastSnapshot = snapshot;
  snapshotReady = true;

  return snapshot;
}

// ============================================================
// JSON
// ============================================================
String buildTelemetryPayload(const TelemetrySnapshot& s) {
  String payload;
  payload.reserve(450);

  payload += "{";
  payload += "\"device_id\":\"" + String(DEVICE_ID) + "\",";
  payload += "\"presence\":" + String(boolToJson(s.presence)) + ",";
  payload += "\"window_open\":" + String(boolToJson(s.windowOpen)) + ",";
  payload += "\"temp_ok\":" + String(boolToJson(s.tempOk)) + ",";
  payload += "\"temp_c\":" + String(s.tempC, 1) + ",";
  payload += "\"humidity\":" + String(s.humidity, 1) + ",";
  payload += "\"current_a\":" + String(s.currentA, 2) + ",";
  payload += "\"power_w\":" + String(s.powerW, 1) + ",";
  payload += "\"energy_total_kwh\":" + String(s.energyTotalKwh, 4) + ",";
  payload += "\"cost_mad\":" + String(s.costMad, 4) + ",";
  payload += "\"lamp_on\":" + String(boolToJson(s.lampOn)) + ",";
  payload += "\"fan_on\":" + String(boolToJson(s.fanOn)) + ",";
  payload += "\"anomaly_dht_fail\":" + String(boolToJson(s.anomalyDhtFail)) + ",";
  payload += "\"alerts\":" + String(s.alerts) + ",";
  payload += "\"remote_enabled\":" + String(boolToJson(s.remoteEnabled));
  payload += "}";

  return payload;
}

// ============================================================
// PARSING JSON
// ============================================================
String extractJsonString(const String& response, const char* key) {
  // Tolere les retours a la ligne et les espaces autour de ':'.
  const String pattern = "\"" + String(key) + "\"";
  const int keyStart = response.indexOf(pattern);
  if (keyStart < 0) return "";

  int pos = keyStart + pattern.length();
  while (pos < (int)response.length() && response[pos] != ':') {
    pos++;
  }
  if (pos >= (int)response.length()) return "";
  pos++;  // saute ':'

  while (pos < (int)response.length() &&
         (response[pos] == ' ' || response[pos] == '\t' ||
          response[pos] == '\r' || response[pos] == '\n')) {
    pos++;
  }

  if (pos >= (int)response.length() || response[pos] != '"') return "";
  pos++;  // saute le guillemet ouvrant

  const int valueEnd = response.indexOf('"', pos);
  if (valueEnd < 0) return "";
  return response.substring(pos, valueEnd);
}

int extractJsonInt(const String& response, const char* key, int defaultValue) {
  // Tolere les retours a la ligne et les espaces autour de ':'.
  const String pattern = "\"" + String(key) + "\"";
  const int keyStart = response.indexOf(pattern);
  if (keyStart < 0) return defaultValue;

  int pos = keyStart + pattern.length();
  while (pos < (int)response.length() && response[pos] != ':') {
    pos++;
  }
  if (pos >= (int)response.length()) return defaultValue;
  pos++;  // saute ':'

  while (pos < (int)response.length() &&
         (response[pos] == ' ' || response[pos] == '\t' ||
          response[pos] == '\r' || response[pos] == '\n')) {
    pos++;
  }

  bool negative = false;
  if (pos < (int)response.length() && response[pos] == '-') {
    negative = true;
    pos++;
  }

  long value = 0;
  bool hasDigit = false;
  while (pos < (int)response.length() && isDigit(response[pos])) {
    hasDigit = true;
    value = (value * 10L) + (response[pos] - '0');
    pos++;
  }

  if (!hasDigit) return defaultValue;
  return negative ? -static_cast<int>(value) : static_cast<int>(value);
}

unsigned long sanitizeSendPeriod(int requestedPeriodMs) {
  if (requestedPeriodMs <= 0) return sendPeriodMs;
  unsigned long sanitized = static_cast<unsigned long>(requestedPeriodMs);
  if (sanitized < MIN_SEND_PERIOD_MS) sanitized = MIN_SEND_PERIOD_MS;
  if (sanitized > MAX_SEND_PERIOD_MS) sanitized = MAX_SEND_PERIOD_MS;
  return sanitized;
}

// ============================================================
// COMMANDES
// ============================================================
String handleCommand(const String& command, int requestedPeriodMs) {
  if (command.length() == 0) return "ignored";
  logInfo("CMD", "Recu: " + command);

  if (command == "lamp_on") {
    setLampState(true);
    logInfo("ACT", "Lampe (LED Verte) ON");
    return "acked";
  }
  else if (command == "lamp_off") {
    setLampState(false);
    logInfo("ACT", "Lampe (LED Verte) OFF");
    return "acked";
  }
  else if (command == "fan_on") {
    fanAutoMode = false;
    setFanState(true);
    logInfo("ACT", "Ventilateur (LED Rouge) ON");
    return "acked";
  }
  else if (command == "fan_off") {
    fanAutoMode = false;
    setFanState(false);
    logInfo("ACT", "Ventilateur (LED Rouge) OFF");
    return "acked";
  }
  else if (command == "fan_auto") {
    fanAutoMode = true;
    logInfo("ACT", "Mode AUTO");
    return "acked";
  }
  else if (command == "window_open") {
    windowManualOverride = true;
    windowManualOpenState = true;
    logInfo("ACT", "Fenetre forcee OUVERTE");
    return "acked";
  }
  else if (command == "window_close") {
    windowManualOverride = true;
    windowManualOpenState = false;
    logInfo("ACT", "Fenetre forcee FERMEe");
    return "acked";
  }
  else if (command == "set_period") {
    if (requestedPeriodMs > 0) {
      sendPeriodMs = sanitizeSendPeriod(requestedPeriodMs);
      logInfo("CFG", "Periode: " + String(sendPeriodMs) + " ms");
      return "acked";
    }
    logInfo("CFG", "Periode invalide.");
    return "failed";
  }
  else if (command == "reboot") {
    requestRestart("commande reboot");
    return "acked";
  }
  else if (command == "reset_energy_totals") {
    resetEnergyTotals();
    logInfo("ACT", "Totaux energie/cout RAZ");
    return "acked";
  }
  else if (command == "reset_study") {
    logInfo("ACT", "Reset audit sans impact sur les compteurs live");
    return "acked";
  }
  else {
    logInfo("CMD", "Non geree: " + command);
    return "unsupported";
  }
}

void acknowledgeCommand(int commandId, const String& status) {
  if (commandId <= 0 || WiFi.status() != WL_CONNECTED) {
    return;
  }

  HTTPClient http;
  const String url = String(getServerBase()) + "/api/cmd_ack";
  beginApiRequest(http, url);
  http.setTimeout(HTTP_TIMEOUT_MS);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("X-API-TOKEN", API_TOKEN);

  const String payload = "{\"id\":" + String(commandId) + ",\"status\":\"" + status + "\"}";
  const int code = http.POST(payload);
  if (code == HTTP_CODE_OK) {
    logInfo("CMD", "Ack " + status + " id=" + String(commandId));
  } else {
    logInfo("CMD", "Ack echec id=" + String(commandId) + " code=" + String(code));
  }
  http.end();
}

// ============================================================
// ENVOI TELEMETRIE
// ============================================================
void sendTelemetry() {
  if (WiFi.status() != WL_CONNECTED) {
    logInfo("INGEST", "WiFi OFF, envoi saute.");
    readTelemetry();
    return;
  }

  const TelemetrySnapshot snapshot = readTelemetry();
  const String payload = buildTelemetryPayload(snapshot);

  HTTPClient http;
  const String url = String(getServerBase()) + "/api/ingest";
  beginApiRequest(http, url);
  http.setTimeout(HTTP_TIMEOUT_MS);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("X-API-TOKEN", API_TOKEN);

  const int code = http.POST(payload);
  logInfo("INGEST", "POST -> " + String(code));

  if (code > 0 && code != 200) {
    logInfo("INGEST", "Reponse: " + http.getString());
  } else if (code <= 0) {
    logInfo("INGEST", "ERR: " + http.errorToString(code));
  }
  http.end();
}

// ============================================================
// PULL COMMANDES
// ============================================================
void pullCommand() {
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  const String url = String(getServerBase()) + "/api/pull_cmd?device_id=" + DEVICE_ID;
  beginApiRequest(http, url);
  http.setTimeout(HTTP_TIMEOUT_MS);
  http.addHeader("X-API-TOKEN", API_TOKEN);

  const int code = http.GET();

  if (code == HTTP_CODE_OK) {
    const String response = http.getString();
    const String command = extractJsonString(response, "command");

    if (command.length() > 0) {
      logInfo("CMD", "Recu: " + response);
      const int commandId = extractJsonInt(response, "id", -1);
      const int requestedPeriodMs = extractJsonInt(response, "period_ms", -1);
      const String status = handleCommand(command, requestedPeriodMs);
      acknowledgeCommand(commandId, status);
    }
  }
  http.end();
}

// ============================================================
// SETUP
// ============================================================
void setup() {
  Serial.begin(115200);
  delay(500);

  Serial.println();
  Serial.println("================================================");
  logInfo("BOOT", "Smart Energy Audit V2 - Mode LED (sans relais)");
  Serial.println("================================================");

  initLcd();
  delay(1000);
  initSecureClient();
  
  configurePins();
  
  lcdShowBoot("Init capteurs");
  dht.begin();
  delay(2000);
  
  calibratePir();
  
  connectWiFiBlocking();

  logInfo("CFG", "Periode: " + String(sendPeriodMs) + " ms");
  logInfo("CFG", "Serveur: " + String(getServerBase()));

  lastCycleMs = millis() - sendPeriodMs;
  lastEnergyUpdateMs = millis();
  lastLcdSwitchMs = millis();
  sampleDhtSensors(millis(), true);
  initializePirTracking();
}

// ============================================================
// LOOP
// ============================================================
void loop() {
  ensureWiFiConnection();
  performPendingRestart();

  const unsigned long now = millis();
  processPirStateChange(now);
  
  if (now - lastCycleMs >= sendPeriodMs) {
    lastCycleMs = now;
    sendTelemetry();
    pullCommand();
    performPendingRestart();
  }
  
  updateLcdRotation();
  updateBuzzer();
  
  delay(20);
}
