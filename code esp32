void lcdScreenAlert(const TelemetrySnapshot& s) {
  lcd.setCursor(0, 0);
  if (s.criticalAlert) {
    lcdPadAndPrint("!! ALERTE !!");
    lcd.setCursor(0, 1);
    if (s.tempC > CRITICAL_TEMP_C) {
      lcdPadAndPrint("Surchauffe!");
    } else if (s.powerW > CRITICAL_POWER_W) {
      lcdPadAndPrint("Surpuissance!");
    } else {
      lcdPadAndPrint("Critique");
    }
  } else {
    lcdPadAndPrint("Anomalie");
    lcd.setCursor(0, 1);
    if (s.anomalyDhtFail) {
      lcdPadAndPrint("Capteur DHT KO");
    } else {
      lcdPadAndPrint("Voir details");
    }
  }
}

void updateLcdRotation() {
  if (!snapshotReady) return;
  
  unsigned long now = millis();
  
  if (lastSnapshot.criticalAlert) {
    if (now - lastLcdRefreshMs >= LCD_REFRESH_MS) {
      lastLcdRefreshMs = now;
      lcdScreenAlert(lastSnapshot);
    }
    return;
  }
  
  if (now - lastLcdSwitchMs >= LCD_SCREEN_DURATION_MS) {
    lastLcdSwitchMs = now;
    currentLcdScreen = (currentLcdScreen + 1) % 4;
    lcd.clear();
  }
  
  if (now - lastLcdRefreshMs >= LCD_REFRESH_MS) {
    lastLcdRefreshMs = now;
    switch (currentLcdScreen) {
      case 0: lcdScreenEnvironment(lastSnapshot); break;
      case 1: lcdScreenEnergy(lastSnapshot); break;
      case 2: lcdScreenActuators(lastSnapshot); break;
      case 3: lcdScreenNetwork(lastSnapshot); break;
    }
  }
}

// ============================================================
// BUZZER
// ============================================================
void updateBuzzer() {
  unsigned long now = millis();
  
  if (!buzzerActive) {
    if (buzzerOn) {
      writeControlledOutput(BUZZER_PIN, false, BUZZER_ACTIVE_HIGH);
      buzzerOn = false;
    }
    return;
  }
  
  bool isCritical = lastSnapshot.criticalAlert;
  unsigned long onMs = isCritical ? BUZZER_CRITICAL_ON_MS : BUZZER_BEEP_ON_MS;
  unsigned long offMs = isCritical ? BUZZER_CRITICAL_OFF_MS : BUZZER_BEEP_OFF_MS;
  
  if (buzzerOn) {
    if (now - lastBuzzerToggleMs >= onMs) {
      writeControlledOutput(BUZZER_PIN, false, BUZZER_ACTIVE_HIGH);
      buzzerOn = false;
      lastBuzzerToggleMs = now;
    }
  } else {
    if (now - lastBuzzerToggleMs >= offMs) {
      writeControlledOutput(BUZZER_PIN, true, BUZZER_ACTIVE_HIGH);
      buzzerOn = true;
      lastBuzzerToggleMs = now;
    }
  }
}

void setBuzzerActive(bool active) {
  buzzerActive = active;
  if (!active && buzzerOn) {
    writeControlledOutput(BUZZER_PIN, false, BUZZER_ACTIVE_HIGH);
    buzzerOn = false;
  }
}

